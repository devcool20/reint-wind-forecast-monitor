# Copy to .env to override defaults (optional for local dev; all have defaults)
APP_ENV=development
LOG_LEVEL=INFO

BMRS_BASE_URL=https://data.elexon.co.uk/bmrs/api/v1
BMRS_TIMEOUT_SECONDS=20
BMRS_MAX_RETRIES=3
BMRS_BACKOFF_SECONDS=0.5

CORS_ALLOW_ORIGINS=http://localhost:3000

MIN_HORIZON_HOURS=0
MAX_HORIZON_HOURS=48
DEFAULT_HORIZON_HOURS=4

JANUARY_START_UTC=2024-01-01T00:00:00Z
JANUARY_END_UTC=2024-02-01T00:00:00Z

